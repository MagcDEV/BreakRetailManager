@page "/"
@inject AccountsControlApiClient AccountsApi
@inject NavigationManager Navigation
@inject UserRoleProvider RoleProvider

<PageTitle>Break Retail</PageTitle>

@if (!string.IsNullOrWhiteSpace(statusMessage))
{
    <div class="alert @statusCss alert-dismissible" role="alert">
        @statusMessage
        <button type="button" class="btn-close" @onclick="() => statusMessage = null"></button>
    </div>
}

<div style="text-align: center; padding: 3rem 1rem 2rem;">
    <img src="images/logo.png" alt="Break Retail logo" style="width: 140px; height: 140px; object-fit: contain; margin-bottom: 1.5rem;" />
    <h1 style="font-size: 2.25rem; margin-bottom: 0.25rem;">Break Retail</h1>
    <p style="color: #c9a96e; font-family: 'DM Sans', sans-serif; font-size: 0.8rem; letter-spacing: 0.2em; text-transform: uppercase; margin-bottom: 2rem;">Point of Sale &bull; Inventory &bull; Management</p>
    <p style="color: #6b6b6b; max-width: 560px; margin: 0 auto; line-height: 1.7;">
        Choose an accounts-control access path below. Employee and general-expense access stay lightweight in v1, while administrator access uses the existing Break Retail sign-in flow.
    </p>
</div>

@if (isLoading)
{
    <p class="text-center"><em>Loading accounts access...</em></p>
}
else
{
    <div class="row g-4">
        <div class="col-12">
            <div class="card border-@(summary?.TotalOutstandingBalance > 0 ? "danger" : "success")">
                <div class="card-body text-center">
                    <div class="text-muted text-uppercase small">Store outstanding balance</div>
                    <div class="display-5 fw-semibold @(summary?.TotalOutstandingBalance > 0 ? "text-danger" : "text-success")">
                        @(summary?.TotalOutstandingBalance.ToString("C") ?? "Unavailable")
                    </div>
                    <div class="small text-muted mt-2">
                        General expenses: @(summary?.TotalGeneralExpenseBalance.ToString("C") ?? "-")
                        <span class="mx-2">&bull;</span>
                        Collected: @(summary?.TotalCollected.ToString("C") ?? "-")
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card h-100">
                <div class="card-header bg-primary text-white">
                    <strong>Employee</strong>
                </div>
                <div class="card-body d-flex flex-column">
                    <p class="text-muted">View your balance, add a positive debt movement, and review your own history.</p>
                    <label class="form-label">Employee account</label>
                    <select class="form-select mb-3" value="@selectedEmployeeId" @onchange="OnEmployeeChanged">
                        <option value="">Select an employee...</option>
                        @foreach (var account in employeeAccounts)
                        {
                            <option value="@account.Id">@account.Name</option>
                        }
                    </select>
                    <button class="btn btn-primary mt-auto" @onclick="OpenEmployeeAccount">Continue</button>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card h-100">
                <div class="card-header bg-secondary text-white">
                    <strong>General expense</strong>
                </div>
                <div class="card-body d-flex flex-column">
                    <p class="text-muted">Register positive expense movements and review the selected account history.</p>
                    <label class="form-label">Expense account</label>
                    <select class="form-select mb-3" value="@selectedExpenseId" @onchange="OnExpenseChanged">
                        <option value="">Select an expense account...</option>
                        @foreach (var account in expenseAccounts)
                        {
                            <option value="@account.Id">@account.Name</option>
                        }
                    </select>
                    <button class="btn btn-secondary mt-auto" @onclick="OpenExpenseAccount">Continue</button>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card h-100">
                <div class="card-header bg-dark text-white">
                    <strong>Administrator</strong>
                </div>
                <div class="card-body d-flex flex-column">
                    <p class="text-muted">Open the accounts dashboard, manage accounts, review movements, and apply adjustments.</p>
                    <AuthorizeView>
                        <Authorized>
                            @if (IsAdmin)
                            {
                                <div class="alert alert-success" role="alert">
                                    You are signed in with administrator access.
                                </div>
                                <button class="btn btn-dark mt-auto" @onclick="OpenAdminDashboard">Open dashboard</button>
                            }
                            else
                            {
                                <div class="alert alert-warning mb-0" role="alert">
                                    Sign in with an account that has the existing <code>Admin</code> role to access this area.
                                </div>
                            }
                        </Authorized>
                        <NotAuthorized>
                            <div class="alert alert-info" role="alert">
                                Administrator access uses the existing Break Retail sign-in flow.
                            </div>
                            <button class="btn btn-dark mt-auto" @onclick="OpenAdminLogin">Sign in</button>
                        </NotAuthorized>
                    </AuthorizeView>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private PublicSummaryDto? summary;
    private IReadOnlyList<AccountOptionDto> employeeAccounts = [];
    private IReadOnlyList<AccountOptionDto> expenseAccounts = [];
    private string selectedEmployeeId = string.Empty;
    private string selectedExpenseId = string.Empty;
    private bool isLoading = true;
    private string? statusMessage;
    private string statusCss = "alert-info";

    private bool IsAdmin => RoleProvider.Roles.Contains("Admin", StringComparer.OrdinalIgnoreCase);

    protected override async Task OnInitializedAsync()
    {
        await RoleProvider.InitializeAsync();

        var summaryTask = AccountsApi.GetPublicSummaryAsync();
        var employeesTask = AccountsApi.GetEmployeeAccountsAsync();
        var expensesTask = AccountsApi.GetExpenseAccountsAsync();

        await Task.WhenAll(summaryTask, employeesTask, expensesTask);

        summary = await summaryTask;
        employeeAccounts = await employeesTask;
        expenseAccounts = await expensesTask;
        isLoading = false;
    }

    private void OnEmployeeChanged(ChangeEventArgs args)
    {
        selectedEmployeeId = args.Value?.ToString() ?? string.Empty;
    }

    private void OnExpenseChanged(ChangeEventArgs args)
    {
        selectedExpenseId = args.Value?.ToString() ?? string.Empty;
    }

    private void OpenEmployeeAccount()
    {
        if (!Guid.TryParse(selectedEmployeeId, out var accountId))
        {
            statusCss = "alert-warning";
            statusMessage = "Select an employee account first.";
            return;
        }

        Navigation.NavigateTo($"/accounts/employee/{accountId}");
    }

    private void OpenExpenseAccount()
    {
        if (!Guid.TryParse(selectedExpenseId, out var accountId))
        {
            statusCss = "alert-warning";
            statusMessage = "Select an expense account first.";
            return;
        }

        Navigation.NavigateTo($"/accounts/expense/{accountId}");
    }

    private void OpenAdminLogin()
    {
        Navigation.NavigateTo("authentication/login");
    }

    private void OpenAdminDashboard()
    {
        Navigation.NavigateTo("/accounts/admin");
    }
}
